@model MinisterioGosen.Models.ActividadModel

@{
    ViewData["Title"] = "Nueva actividad";
}

<div class="container py-4">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h2 class="fw-bold mb-1">
                <i class="bi bi-calendar-plus-fill me-2 text-primary"></i>
                Nueva actividad
            </h2>
            <p class="text-muted mb-0">
                Registre una nueva actividad del Ministerio Gosén.
            </p>
        </div>

        <a asp-controller="Actividad"
           asp-action="Index"
           class="btn btn-outline-secondary rounded-pill px-4">
            <i class="bi bi-arrow-left me-1"></i>
            Volver
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">

            @if (ViewBag.Mensaje != null)
            {
                <div class="alert alert-warning d-flex align-items-center gap-2 rounded-3">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span>@ViewBag.Mensaje</span>
                </div>
            }

            <div id="mensajeValidacion" class="alert alert-danger d-none">
                <i class="bi bi-exclamation-triangle-fill me-1"></i>
                <span id="textoValidacion"></span>
            </div>

            <form asp-action="Crear"
                  asp-controller="Actividad"
                  method="post"
                  id="formActividad"
                  novalidate>

                <div class="row g-4">

                    <div class="col-md-8">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-calendar-event-fill me-1 text-muted"></i>
                            Nombre de la actividad
                        </label>
                        <input asp-for="Nombre_Actividad"
                               class="form-control rounded-3"
                               placeholder="Ingrese el nombre de la actividad" />
                        <div class="invalid-feedback">
                            Debe ingresar el nombre de la actividad.
                        </div>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-tag-fill me-1 text-muted"></i>
                            Tipo de actividad
                        </label>
                        <select asp-for="Id_Tipo_Actividad"
                                asp-items="ViewBag.TiposActividad"
                                class="form-select rounded-3">
                            <option value="">Seleccione un tipo</option>
                        </select>
                        <div class="invalid-feedback">
                            Debe seleccionar un tipo de actividad.
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-people-fill me-1 text-muted"></i>
                            Ministerio responsable
                        </label>
                        <select asp-for="Id_Ministerio"
                                asp-items="ViewBag.Ministerios"
                                class="form-select rounded-3">
                            <option value="">Sin ministerio asignado</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-chat-left-text-fill me-1 text-muted"></i>
                            Observación del ministerio
                        </label>
                        <input asp-for="Observacion_Ministerio_Actividad"
                               class="form-control rounded-3"
                               placeholder="Observación opcional" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-calendar-date me-1 text-muted"></i>
                            Fecha de inicio
                        </label>
                        <input asp-for="Fecha_Ini"
                               type="date"
                               class="form-control rounded-3"
                               min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        <div class="invalid-feedback">
                            Debe ingresar una fecha de inicio válida. No puede ser anterior a la fecha actual.
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-calendar-check me-1 text-muted"></i>
                            Fecha de finalización
                        </label>
                        <input asp-for="Fecha_Fin"
                               type="date"
                               class="form-control rounded-3" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-clock-fill me-1 text-muted"></i>
                            Hora de inicio
                        </label>
                        <input asp-for="Hora_Ini"
                               type="time"
                               class="form-control rounded-3" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-clock-history me-1 text-muted"></i>
                            Hora de finalización
                        </label>
                        <input asp-for="Hora_Fin"
                               type="time"
                               class="form-control rounded-3" />
                    </div>

                    <div class="col-md-12">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-geo-alt-fill me-1 text-muted"></i>
                            Lugar
                        </label>
                        <input asp-for="Lugar"
                               class="form-control rounded-3"
                               placeholder="Ingrese el lugar de la actividad" />
                    </div>

                </div>

                <hr class="my-4" />

                <div class="d-flex justify-content-end gap-2">
                    <a asp-controller="Actividad"
                       asp-action="Index"
                       class="btn btn-outline-secondary rounded-pill px-4">
                        Cancelar
                    </a>

                    <button type="submit"
                            class="btn btn-primary rounded-pill px-4">
                        <i class="bi bi-save-fill me-1"></i>
                        Guardar actividad
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/actividad.js" asp-append-version="true"></script>
}