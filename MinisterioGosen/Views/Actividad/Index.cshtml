@model List<MinisterioGosen.Models.ActividadModel>

@{
    ViewData["Title"] = "Administrar actividades";

    var actividades = Model ?? new List<MinisterioGosen.Models.ActividadModel>();
    var totalActividades = actividades.Count;
}

<div class="container py-4">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h2 class="fw-bold mb-1">
                <i class="bi bi-calendar-event-fill me-2 text-primary"></i>
                Actividades
            </h2>
            <p class="text-muted mb-0">
                Administración de actividades registradas en el sistema.
            </p>
        </div>

        <a asp-controller="Actividad"
           asp-action="Crear"
           class="btn btn-primary rounded-pill px-4">
            <i class="bi bi-plus-circle-fill me-1"></i>
            Nueva actividad
        </a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center"
                         style="width:48px;height:48px;">
                        <i class="bi bi-calendar-check-fill text-primary fs-4"></i>
                    </div>

                    <div>
                        <p class="text-muted mb-0 small">Total actividades</p>
                        <h4 class="fw-bold mb-0">@totalActividades</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white border-0 px-4 pt-4 pb-2">
            <h5 class="fw-bold mb-0">
                <i class="bi bi-list-ul me-2 text-primary"></i>
                Listado de actividades
            </h5>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Actividad</th>
                            <th>Tipo</th>
                            <th>Fecha</th>
                            <th>Horario</th>
                            <th>Lugar</th>
                            <th class="text-end pe-4">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (actividades.Any())
                        {
                            foreach (var item in actividades)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center"
                                                 style="width:36px;height:36px;min-width:36px;">
                                                <i class="bi bi-calendar-event text-primary"></i>
                                            </div>

                                            <div>
                                                <span class="fw-semibold">@item.Nombre_Actividad</span>
                                                <div class="small text-muted">#@item.Id_Actividad</div>
                                            </div>
                                        </div>
                                    </td>

                                    <td>
                                        <span class="badge rounded-pill bg-info text-dark px-3 py-2">
                                            <i class="bi bi-tag-fill me-1"></i>
                                            @item.Nombre_Tipo
                                        </span>
                                    </td>

                                    <td>
                                        <div class="small">
                                            <div>
                                                <i class="bi bi-calendar-date me-1 text-muted"></i>
                                                @item.Fecha_Ini.ToString("dd/MM/yyyy")
                                            </div>

                                            @if (item.Fecha_Fin != null)
                                            {
                                                <div class="text-muted">
                                                    hasta @item.Fecha_Fin.Value.ToString("dd/MM/yyyy")
                                                </div>
                                            }
                                        </div>
                                    </td>

                                    <td>
                                        @if (!string.IsNullOrEmpty(item.Hora_Ini))
                                        {
                                            <span>
                                                <i class="bi bi-clock me-1 text-muted"></i>
                                                @item.Hora_Ini
                                                @if (!string.IsNullOrEmpty(item.Hora_Fin))
                                                {
                                                    <span> - @item.Hora_Fin</span>
                                                }
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Sin horario</span>
                                        }
                                    </td>

                                    <td>
                                        @if (!string.IsNullOrEmpty(item.Lugar))
                                        {
                                            <span>
                                                <i class="bi bi-geo-alt-fill me-1 text-muted"></i>
                                                @item.Lugar
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Sin lugar</span>
                                        }
                                    </td>

                                    <td class="text-end pe-4">
                                        <div class="btn-group" role="group">
                                            <a asp-controller="Actividad"
                                               asp-action="Editar"
                                               asp-route-id="@item.Id_Actividad"
                                               class="btn btn-sm btn-outline-primary"
                                               title="Editar">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>

                                            <a asp-controller="Actividad"
                                               asp-action="Eliminar"
                                               asp-route-id="@item.Id_Actividad"
                                               class="btn btn-sm btn-outline-danger"
                                               title="Eliminar">
                                                <i class="bi bi-trash-fill"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5">
                                    <i class="bi bi-calendar-x text-muted" style="font-size: 3rem;"></i>

                                    <h5 class="fw-bold text-muted mt-3 mb-1">
                                        No hay actividades registradas
                                    </h5>

                                    <p class="text-muted mb-3">
                                        Cuando se creen actividades, aparecerán en este listado.
                                    </p>

                                    <a asp-controller="Actividad"
                                       asp-action="Crear"
                                       class="btn btn-primary rounded-pill px-4">
                                        <i class="bi bi-plus-circle-fill me-1"></i>
                                        Crear actividad
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>