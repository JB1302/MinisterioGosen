@model List<MinisterioGosen.Models.CitasModel>

@{
    ViewData["Title"] = "Citas";

    var citas = Model ?? new List<MinisterioGosen.Models.CitasModel>();

    var totalCitas = citas.Count;
    var totalPendientes = citas.Count(x => x.Estado == "Pendiente");
    var totalAtendidas = citas.Count(x => x.Estado == "Atendida");
}

<div class="container py-4">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h2 class="fw-bold mb-1">
                <i class="bi bi-calendar2-check-fill me-2 text-primary"></i>
                Citas
            </h2>
            <p class="text-muted mb-0">
                Administración de citas agendadas en el sistema.
            </p>
        </div>
    </div>

    <div class="row g-3 mb-4">

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                        <i class="bi bi-calendar2-check-fill text-primary fs-4"></i>
                    </div>

                    <div>
                        <p class="text-muted mb-0 small">Total citas</p>
                        <h4 class="fw-bold mb-0">@totalCitas</h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-warning bg-opacity-10 p-3">
                        <i class="bi bi-hourglass-split text-warning fs-4"></i>
                    </div>

                    <div>
                        <p class="text-muted mb-0 small">Pendientes</p>
                        <h4 class="fw-bold mb-0">@totalPendientes</h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-success bg-opacity-10 p-3">
                        <i class="bi bi-check-circle-fill text-success fs-4"></i>
                    </div>

                    <div>
                        <p class="text-muted mb-0 small">Atendidas</p>
                        <h4 class="fw-bold mb-0">@totalAtendidas</h4>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white border-0 px-4 pt-4 pb-2">
            <h5 class="fw-bold mb-0">
                <i class="bi bi-list-ul me-2 text-primary"></i>
                Listado de citas
            </h5>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Código</th>
                            <th>Fecha</th>
                            <th>Solicitante</th>
                            <th>Encargado</th>
                            <th>Observación inicial</th>
                            <th>Estado</th>
                            <th class="text-end pe-4">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (citas.Any())
                        {
                            foreach (var item in citas)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <span class="badge rounded-pill bg-secondary px-3 py-2">
                                            #@item.Id_Cita
                                        </span>
                                    </td>

                                    <td>
                                        <div class="small">
                                            <i class="bi bi-calendar-date me-1 text-primary"></i>
                                            @item.Fecha_Cita.ToString("dd/MM/yyyy")
                                        </div>
                                    </td>

                                    <td>
                                        <div class="fw-semibold">
                                            <i class="bi bi-person-fill me-1 text-muted"></i>
                                            @(string.IsNullOrEmpty(item.Nombre_Usuario_Cita) ? $"Usuario #{item.Id_Usuario_Cita}" : item.Nombre_Usuario_Cita)
                                        </div>
                                    </td>

                                    <td>
                                        <span class="badge rounded-pill bg-primary bg-opacity-10 text-primary px-3 py-2">
                                            <i class="bi bi-person-badge-fill me-1"></i>
                                            @(string.IsNullOrEmpty(item.Nombre_Usuario_Encargado) ? $"Usuario #{item.Id_Usuario_Encargado}" : item.Nombre_Usuario_Encargado)
                                        </span>
                                    </td>

                                    <td>
                                        @if (!string.IsNullOrEmpty(item.Observacion_Inicial))
                                        {
                                            <span class="text-truncate d-inline-block" style="max-width: 220px;">
                                                @item.Observacion_Inicial
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Sin observación</span>
                                        }
                                    </td>

                                    <td>
                                        @if (item.Estado == "Atendida")
                                        {
                                            <span class="badge rounded-pill bg-success px-3 py-2">
                                                <i class="bi bi-check-circle-fill me-1"></i>
                                                Atendida
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill bg-warning text-dark px-3 py-2">
                                                <i class="bi bi-hourglass-split me-1"></i>
                                                Pendiente
                                            </span>
                                        }
                                    </td>

                                    <td class="text-end pe-4">
                                        <div class="btn-group" role="group">
                                            <a asp-controller="Citas"
                                               asp-action="Editar"
                                               asp-route-id="@item.Id_Cita"
                                               class="btn btn-sm btn-outline-primary"
                                               title="Editar">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>

                                            @if (item.Estado != "Atendida")
                                            {
                                                <a asp-controller="Citas"
                                                   asp-action="Atender"
                                                   asp-route-id="@item.Id_Cita"
                                                   class="btn btn-sm btn-outline-success"
                                                   title="Atender">
                                                    <i class="bi bi-check-circle"></i>
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5">
                                    <i class="bi bi-calendar-x text-muted display-4"></i>

                                    <h5 class="fw-bold text-muted mt-3 mb-1">
                                        No hay citas registradas
                                    </h5>

                                    <p class="text-muted mb-3">
                                        Cuando se agenden citas, aparecerán en este listado.
                                    </p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (TempData["CitaAtendida"] != null)
    {
        <div class="modal fade" id="modalCitaAtendida" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content rounded-4 border-0 shadow">
                    <div class="modal-body text-center p-4">
                        <div class="rounded-circle bg-success bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3"
                             style="width: 72px; height: 72px;">
                            <i class="bi bi-check-circle-fill text-success" style="font-size: 2.5rem;"></i>
                        </div>

                        <h5 class="fw-bold mb-2">¡Cita atendida!</h5>
                        <p class="text-muted mb-4">
                            La cita fue marcada como atendida correctamente.
                        </p>

                        <button type="button" class="btn btn-primary rounded-pill px-4" data-bs-dismiss="modal">
                            Aceptar
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

</div>

@section Scripts {
    @if (TempData["CitaAtendida"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                var modal = new bootstrap.Modal(document.getElementById("modalCitaAtendida"));
                modal.show();
            });
        </script>
    }
}