@model MinisterioGosen.Models.CitasModel

@{
    ViewData["Title"] = "Editar cita";
}

<div class="container py-4">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h2 class="fw-bold mb-1">
                <i class="bi bi-pencil-square me-2 text-primary"></i>
                Editar cita
            </h2>
            <p class="text-muted mb-0">
                Actualice la información de la cita seleccionada.
            </p>
        </div>

        <a asp-controller="Citas"
           asp-action="Index"
           class="btn btn-outline-secondary rounded-pill px-4">
            <i class="bi bi-arrow-left me-1"></i>
            Volver
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">

            @if (ViewBag.Mensaje != null)
            {
                <div class="alert alert-warning d-flex align-items-center gap-2 rounded-3">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span>@ViewBag.Mensaje</span>
                </div>
            }

            <div id="mensajeValidacion" class="alert alert-danger d-none">
                <i class="bi bi-exclamation-triangle-fill me-1"></i>
                <span id="textoValidacion"></span>
            </div>

            <form asp-action="Editar"
                  asp-controller="Citas"
                  method="post"
                  id="formCita"
                  novalidate>

                <input asp-for="Id_Cita" type="hidden" />
                <input asp-for="Id_Usuario_Cita" type="hidden" />
                <input asp-for="Estado" type="hidden" />

                <div class="row g-4">

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-hash me-1 text-muted"></i>
                            Código
                        </label>
                        <input value="@Model.Id_Cita"
                               class="form-control rounded-3"
                               readonly />
                    </div>

                    <div class="col-md-8">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-person-fill me-1 text-muted"></i>
                            Solicitante
                        </label>
                        <input value="@(string.IsNullOrEmpty(Model.Nombre_Usuario_Cita) ? $"Usuario #{Model.Id_Usuario_Cita}" : Model.Nombre_Usuario_Cita)"
                               class="form-control rounded-3"
                               readonly />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-flag-fill me-1 text-muted"></i>
                            Estado
                        </label>
                        <input value="@Model.Estado"
                               class="form-control rounded-3"
                               readonly />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-calendar-date me-1 text-muted"></i>
                            Fecha de la cita
                        </label>
                        <input asp-for="Fecha_Cita"
                               type="date"
                               class="form-control rounded-3"
                               min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        <div class="invalid-feedback">
                            Debe ingresar una fecha válida. No puede ser anterior a la fecha actual.
                        </div>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-clock me-1 text-muted"></i>
                            Hora de la cita
                        </label>
                        <input asp-for="Hora_Cita"
                               type="time"
                               class="form-control rounded-3"
                               min="08:00"
                               max="17:00" />
                        <div class="invalid-feedback">
                            Debe ingresar una hora válida entre las 08:00 y las 17:00.
                        </div>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-person-badge-fill me-1 text-muted"></i>
                            Encargado
                        </label>
                        <select asp-for="Id_Usuario_Encargado"
                                asp-items="ViewBag.Encargados"
                                class="form-select rounded-3">
                            <option value="">Seleccione un encargado</option>
                        </select>
                        <div class="invalid-feedback">
                            Debe seleccionar un encargado.
                        </div>
                    </div>

                    <div class="col-md-12">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-chat-left-text-fill me-1 text-muted"></i>
                            Observación inicial
                        </label>
                        <textarea asp-for="Observacion_Inicial"
                                  class="form-control rounded-3"
                                  rows="2"
                                  maxlength="200"></textarea>
                    </div>

                    <div class="col-md-12">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-file-text-fill me-1 text-muted"></i>
                            Detalle
                        </label>
                        <textarea asp-for="Detalle_Cita"
                                  class="form-control rounded-3"
                                  rows="4"
                                  maxlength="500"></textarea>
                    </div>

                </div>

                <hr class="my-4" />

                <div class="d-flex justify-content-end gap-2">
                    <a asp-controller="Citas"
                       asp-action="Index"
                       class="btn btn-outline-secondary rounded-pill px-4">
                        Cancelar
                    </a>

                    <button type="submit"
                            class="btn btn-primary rounded-pill px-4">
                        <i class="bi bi-save-fill me-1"></i>
                        Guardar cambios
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/citas.js" asp-append-version="true"></script>
}