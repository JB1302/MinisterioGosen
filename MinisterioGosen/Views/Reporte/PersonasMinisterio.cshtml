@model List<MinisterioGosen.Models.UsuariosMinisterioModel>

@{
    ViewData["Title"] = "Reporte de personas por ministerio";
}

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="text-uppercase text-primary mb-1">Reportes internos</h4>
            <h1 class="fw-bold mb-0">Personas por ministerio</h1>
        </div>

        <a asp-controller="Reporte"
           asp-action="Index"
           class="btn btn-secondary rounded-pill px-4">
            Volver
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">

            <form method="get" asp-controller="Reporte" asp-action="PersonasMinisterio">
                <div class="row g-3">

                    <div class="col-md-3">
                        <label class="form-label">Buscar</label>
                        <input type="text"
                               name="buscar"
                               value="@ViewBag.Buscar"
                               class="form-control"
                               placeholder="Persona, correo o ministerio">
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Ministerio</label>
                        <select name="idMinisterio"
                                class="form-select"
                                asp-items="ViewBag.Ministerios">
                            <option value="">Todos</option>
                        </select>
                    </div>

                    <div class="col-md-2">
                        <label class="form-label">Estado</label>
                        <select name="estado" class="form-select">
                            <option value="">Todos</option>
                            <option value="Activo" selected="@(ViewBag.Estado == "Activo")">Activo</option>
                            <option value="Inactivo" selected="@(ViewBag.Estado == "Inactivo")">Inactivo</option>
                        </select>
                    </div>

                    <div class="col-md-2">
                        <label class="form-label">Desde</label>
                        <input type="date"
                               name="fechaInicio"
                               value="@ViewBag.FechaInicio"
                               class="form-control">
                    </div>

                    <div class="col-md-2">
                        <label class="form-label">Hasta</label>
                        <input type="date"
                               name="fechaFin"
                               value="@ViewBag.FechaFin"
                               class="form-control">
                    </div>

                    <div class="col-12 d-flex gap-2 justify-content-end">
                        <a asp-controller="Reporte"
                           asp-action="PersonasMinisterio"
                           class="btn btn-outline-secondary">
                            Limpiar
                        </a>

                        <button type="submit" class="btn btn-primary">
                            Filtrar
                        </button>
                    </div>

                </div>
            </form>

        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-dark text-white rounded-top-4">
            <h5 class="mb-0">Resultados encontrados: @Model.Count</h5>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Ministerio</th>
                            <th>Persona</th>
                            <th>Correo</th>
                            <th>Rol</th>
                            <th>Fecha ingreso</th>
                            <th>Fecha salida</th>
                            <th>Estado</th>
                            <th>Observación</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Descripcion_Ministerio</td>
                                    <td>@item.Nombre</td>
                                    <td>@item.Correo</td>
                                    <td>@item.Rol</td>
                                    <td>@item.Fecha_Ingreso?.ToString("dd/MM/yyyy")</td>
                                    <td>@item.Fecha_Salida?.ToString("dd/MM/yyyy")</td>
                                    <td>@item.Estado</td>
                                    <td>@item.Observacion</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center py-4">
                                    No se encontraron registros con los filtros seleccionados.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>