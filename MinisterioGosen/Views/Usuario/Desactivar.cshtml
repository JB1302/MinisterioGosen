@model MinisterioGosen.Models.UsuarioModel

@{
    ViewData["Title"] = "Desactivar persona";
}

<div class="container py-4">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h2 class="fw-bold mb-1">
                <i class="bi bi-person-x-fill me-2 text-danger"></i>
                Desactivar persona
            </h2>
            <p class="text-muted mb-0">
                Confirme si desea desactivar el acceso de este usuario al sistema.
            </p>
        </div>

        <a asp-controller="Usuario"
           asp-action="Index"
           class="btn btn-outline-secondary rounded-pill px-4">
            <i class="bi bi-arrow-left me-1"></i>
            Volver
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">

            @if (ViewBag.Mensaje != null)
            {
                <div class="alert alert-warning d-flex align-items-center gap-2">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span>@ViewBag.Mensaje</span>
                </div>
            }

            <div class="alert alert-danger border-0 rounded-4 d-flex gap-3 align-items-start">
                <i class="bi bi-exclamation-triangle-fill fs-3"></i>

                <div>
                    <h5 class="fw-bold mb-1">Confirmación requerida</h5>
                    <p class="mb-0">
                        Esta acción no eliminará físicamente el usuario, pero impedirá que pueda iniciar sesión mientras esté inactivo.
                    </p>
                </div>
            </div>

            <div class="row g-3 my-4">
                <div class="col-md-6">
                    <div class="p-3 bg-light rounded-4">
                        <p class="text-muted small mb-1">Identificación</p>
                        <h6 class="fw-bold mb-0">@Model.Identificacion</h6>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="p-3 bg-light rounded-4">
                        <p class="text-muted small mb-1">Nombre</p>
                        <h6 class="fw-bold mb-0">@Model.Nombre</h6>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="p-3 bg-light rounded-4">
                        <p class="text-muted small mb-1">Correo</p>
                        <h6 class="fw-bold mb-0">@Model.Correo</h6>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Rol))
                {
                    <div class="col-md-6">
                        <div class="p-3 bg-light rounded-4">
                            <p class="text-muted small mb-1">Rol</p>
                            <h6 class="fw-bold mb-0">@Model.Rol</h6>
                        </div>
                    </div>
                }

            </div>

            <form asp-controller="Usuario" asp-action="ConfirmarDesactivar" method="post">
                <input asp-for="Id_Usuario" type="hidden" />
                <input asp-for="Identificacion" type="hidden" />
                <input asp-for="Nombre" type="hidden" />
                <input asp-for="Correo" type="hidden" />
                <input asp-for="Rol" type="hidden" />

                <div class="d-flex justify-content-end gap-2">
                    <a asp-controller="Usuario"
                       asp-action="Index"
                       class="btn btn-outline-secondary rounded-pill px-4">
                        Cancelar
                    </a>

                    <button type="submit"
                            class="btn btn-danger rounded-pill px-4">
                        <i class="bi bi-person-x-fill me-1"></i>
                        Desactivar usuario
                    </button>
                </div>
            </form>

        </div>
    </div>

</div>