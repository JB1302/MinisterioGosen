@model List<MinisterioGosen.Models.ActividadMinisterioModel>

@{
    ViewData["Title"] = "Actividades por ministerio";

    var actividadesMinisterios = Model ?? new List<MinisterioGosen.Models.ActividadMinisterioModel>();
}

<div class="container py-4">

    <div class="card-body py-4">
        <div class="d-flex flex-column flex-md-row align-items-center justify-content-center gap-3 text-center text-md-start">
            <div>
                <i class="bi bi-building-fill text-primary display-5"></i>
            </div>

            <div>
                <h2 class="fw-bold mb-1">
                    Actividades de ministerios
                </h2>

                <p class="text-muted mb-0">
                    Consulte las actividades asignadas a cada ministerio del Ministerio Gosén.
                </p>
            </div>
        </div>
    </div>

    @if (actividadesMinisterios.Any())
    {
        <div class="row g-4">
            @foreach (var item in actividadesMinisterios)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100">

                        <div class="card-header bg-light border-0 py-3">
                            <div class="d-flex justify-content-between align-items-center gap-2">
                                <span class="badge rounded-pill text-primary border border-primary px-3 py-2">
                                    <i class="bi bi-calendar-event me-1"></i>
                                    Actividad #@item.Id_Actividad
                                </span>

                                <span class="badge rounded-pill bg-white text-success border border-success px-3 py-2">
                                    Ministerio #@item.Id_Ministerio
                                </span>
                            </div>
                        </div>

                        <div class="card-body p-4">

                            <div class="d-flex align-items-start gap-3 mb-4">
                                <div class="bg-primary bg-opacity-10 text-primary rounded-circle p-3">
                                    <i class="bi bi-people-fill fs-4"></i>
                                </div>

                                <div>
                                    <h5 class="fw-bold mb-1">
                                        @item.NombreMinisterio
                                    </h5>

                                    <p class="text-muted small mb-0">
                                        Actividad: @item.NombreActividad
                                    </p>
                                </div>
                            </div>

                            <div class="list-group list-group-flush">

                                @if (item.Fecha.HasValue)
                                {
                                    <div class="list-group-item px-0 d-flex align-items-center gap-3">
                                        <i class="bi bi-calendar-date text-primary fs-5"></i>
                                        <div>
                                            <div class="small text-muted">Fecha</div>
                                            <div class="fw-semibold">@item.Fecha.Value.ToString("dd/MM/yyyy")</div>
                                        </div>
                                    </div>
                                }

                                @if (!string.IsNullOrEmpty(item.Observacion))
                                {
                                    <div class="list-group-item px-0 d-flex align-items-center gap-3">
                                        <i class="bi bi-chat-left-text text-primary fs-5"></i>
                                        <div>
                                            <div class="small text-muted">Observación</div>
                                            <div class="fw-semibold">@item.Observacion</div>
                                        </div>
                                    </div>
                                }

                            </div>

                        </div>

                        <div class="card-footer bg-light border-0 text-end py-3">
                            <span class="text-muted small">
                                <i class="bi bi-info-circle me-1"></i>
                                Información de actividad-ministerio
                            </span>
                        </div>

                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body text-center py-5">
                <i class="bi bi-x-circle text-muted display-3"></i>

                <h4 class="fw-bold text-muted mt-3 mb-2">
                    No hay actividades registradas
                </h4>

                <p class="text-muted mb-0">
                    Cuando se asignen ministerios a actividades, aparecerán en esta sección.
                </p>
            </div>
        </div>
    }

</div>