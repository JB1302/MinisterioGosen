@model List<MinisterioGosen.Models.ActividadMinisterioModel>

@{
    ViewData["Title"] = "Actividades-Ministerios";

    var actividadesMinisterios = Model ?? new List<MinisterioGosen.Models.ActividadMinisterioModel>();
    var totalAsignaciones = actividadesMinisterios.Count;
    var totalConFecha = actividadesMinisterios.Count(x => x.Fecha != null);
}

<div class="container py-4">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h2 class="fw-bold mb-1">
                <i class="bi bi-building-fill me-2 text-primary"></i>
                Actividades-Ministerios
            </h2>
            <p class="text-muted mb-0">
                Administración de ministerios asignados a actividades.
            </p>
        </div>

        <a asp-controller="ActividadMinisterio"
           asp-action="Crear"
           class="btn btn-primary rounded-pill px-4">
            <i class="bi bi-plus-circle-fill me-1"></i>
            Nueva asignación
        </a>
    </div>

    <div class="row g-3 mb-4">

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                        <i class="bi bi-building text-primary fs-4"></i>
                    </div>

                    <div>
                        <p class="text-muted mb-0 small">Total asignaciones</p>
                        <h4 class="fw-bold mb-0">@totalAsignaciones</h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-success bg-opacity-10 p-3">
                        <i class="bi bi-calendar-date text-success fs-4"></i>
                    </div>

                    <div>
                        <p class="text-muted mb-0 small">Con fecha registrada</p>
                        <h4 class="fw-bold mb-0">@totalConFecha</h4>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white border-0 px-4 pt-4 pb-2">
            <h5 class="fw-bold mb-0">
                <i class="bi bi-list-ul me-2 text-primary"></i>
                Listado de asignaciones
            </h5>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Código</th>
                            <th>Actividad</th>
                            <th>Ministerio</th>
                            <th>Fecha</th>
                            <th>Observación</th>
                            <th class="text-end pe-4">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (actividadesMinisterios.Any())
                        {
                            foreach (var item in actividadesMinisterios)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <span class="badge rounded-pill bg-secondary px-3 py-2">
                                            #@item.Id_Minis_Actividad
                                        </span>
                                    </td>

                                    <td>
                                        <div class="fw-semibold">
                                            @item.NombreActividad
                                        </div>
                                    </td>

                                    <td>
                                        <div class="fw-semibold">
                                            <i class="bi bi-people-fill me-1 text-success"></i>
                                            @item.NombreMinisterio
                                        </div>
                                    </td>

                                    <td>
                                        @if (item.Fecha.HasValue)
                                        {
                                            <div class="small">
                                                <i class="bi bi-calendar-date me-1 text-primary"></i>
                                                @item.Fecha.Value.ToString("dd/MM/yyyy")
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Sin fecha</span>
                                        }
                                    </td>

                                    <td>
                                        @if (!string.IsNullOrEmpty(item.Observacion))
                                        {
                                            <span>@item.Observacion</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Sin observación</span>
                                        }
                                    </td>

                                    <td class="text-end pe-4">
                                        <div class="btn-group" role="group">
                                            <a asp-controller="ActividadMinisterio"
                                               asp-action="Editar"
                                               asp-route-id="@item.Id_Minis_Actividad"
                                               class="btn btn-sm btn-outline-primary"
                                               title="Editar">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>

                                            <a asp-controller="ActividadMinisterio"
                                               asp-action="Eliminar"
                                               asp-route-id="@item.Id_Minis_Actividad"
                                               class="btn btn-sm btn-outline-danger"
                                               title="Eliminar">
                                                <i class="bi bi-trash-fill"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5">
                                    <i class="bi bi-x-circle text-muted display-4"></i>

                                    <h5 class="fw-bold text-muted mt-3 mb-1">
                                        No hay asignaciones registradas
                                    </h5>

                                    <p class="text-muted mb-3">
                                        Cuando se asignen ministerios a actividades, aparecerán en este listado.
                                    </p>

                                    <a asp-controller="ActividadMinisterio"
                                       asp-action="Crear"
                                       class="btn btn-primary rounded-pill px-4">
                                        <i class="bi bi-plus-circle-fill me-1"></i>
                                        Crear asignación
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
