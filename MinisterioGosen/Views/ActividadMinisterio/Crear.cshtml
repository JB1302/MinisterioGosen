@model MinisterioGosen.Models.ActividadMinisterioModel

@{
    ViewData["Title"] = "Nueva actividad-ministerio";
}

<div class="container py-4">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h2 class="fw-bold mb-1">
                <i class="bi bi-building-fill me-2 text-primary"></i>
                Nueva actividad-ministerio
            </h2>
            <p class="text-muted mb-0">
                Registre la asignación de un ministerio a una actividad del Ministerio Gosén.
            </p>
        </div>

        <a asp-controller="ActividadMinisterio"
           asp-action="Index"
           class="btn btn-outline-secondary rounded-pill px-4">
            <i class="bi bi-arrow-left me-1"></i>
            Volver
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">

            @if (ViewBag.Mensaje != null)
            {
                <div class="alert alert-warning d-flex align-items-center gap-2 rounded-3">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span>@ViewBag.Mensaje</span>
                </div>
            }

            <form asp-action="Crear"
                  asp-controller="ActividadMinisterio"
                  method="post"
                  id="formActividadMinisterio"
                  novalidate>

                <div class="row g-4">

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-calendar-event-fill me-1 text-muted"></i>
                            Actividad
                        </label>
                        <select asp-for="Id_Actividad"
                                asp-items="ViewBag.Actividades"
                                class="form-select rounded-3">
                            <option value="">Seleccione una actividad</option>
                        </select>
                        <div class="invalid-feedback">
                            Debe seleccionar una actividad.
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-people-fill me-1 text-muted"></i>
                            Ministerio
                        </label>
                        <select asp-for="Id_Ministerio"
                                asp-items="ViewBag.Ministerios"
                                class="form-select rounded-3">
                            <option value="">Seleccione un ministerio</option>
                        </select>
                        <div class="invalid-feedback">
                            Debe seleccionar un ministerio.
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-calendar-date me-1 text-muted"></i>
                            Fecha
                        </label>
                        <input asp-for="Fecha"
                               type="date"
                               class="form-control rounded-3"
                               min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        <div class="invalid-feedback">
                            Debe ingresar una fecha válida.
                        </div>
                    </div>

                    <div class="col-md-12">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-chat-left-text me-1 text-muted"></i>
                            Observación
                        </label>
                        <textarea asp-for="Observacion"
                                  class="form-control rounded-3"
                                  rows="3"
                                  maxlength="200"></textarea>
                        <div class="invalid-feedback">
                            La observación no puede superar 200 caracteres.
                        </div>
                    </div>

                </div>

                <hr class="my-4" />

                <div class="d-flex justify-content-end gap-2">
                    <a asp-controller="ActividadMinisterio"
                       asp-action="Index"
                       class="btn btn-outline-secondary rounded-pill px-4">
                        Cancelar
                    </a>

                    <button type="submit"
                            class="btn btn-primary rounded-pill px-4">
                        <i class="bi bi-save-fill me-1"></i>
                        Guardar actividad-ministerio
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/actividadministerio.js" asp-append-version="true"></script>
}
