@{
    ViewData["Title"] = "Página Principal";
    Layout = "_Layout";
}

<!-- Bienvenidos -->
<div class="container-fluid feature bg-light py-5">
    <div class="container py-5">
        <div class="text-center mx-auto pb-5 wow fadeInUp" data-wow-delay="0.2s" style="max-width: 800px;">
            <h4 class="text-uppercase text-primary">Bienvenidos a nuestra casa</h4>
            <h1 class="display-3 text-capitalize mb-3">Una familia que camina en fe y amor</h1>
            <p>No importa de dónde vengas ni en qué etapa de tu camino espiritual te encuentres; en Gosén siempre hay un lugar para ti</p>
        </div>
        <div class="row g-4 justify-content-center">
            <div class=" col-md-6 col-lg-6 col-xl-3 wow fadeInUp" data-wow-delay="0.2s">
                <div class="feature-item p-4">
                    <div class="feature-icon mb-3"><i class="fas fa-flag text-white fa-3x"></i></div>
                    <a href="#" class="h4 mb-3">Nuestra Misión</a>
                    <p class="mb-3">Discipular con naturalidad, para mostrar y desarrollar la esencia de Jesús.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-6 col-xl-3 wow fadeInUp" data-wow-delay="0.4s">
                <div class="feature-item p-4">
                    <div class="feature-icon mb-3"><i class="fas fa-book-open text-white fa-3x"></i></div>
                    <a href="#" class="h4 mb-3">Nuestra Visión</a>
                    <p class="mb-3">Ser una congregación que ofrezca refugio, amor y seguridad, donde los discípulos crezcan integralmente en Cristo.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-6 col-xl-3 wow fadeInUp" data-wow-delay="0.6s">
                <div class="feature-item p-4">
                    <div class="feature-icon mb-3"><i class="fas fa-heart text-white fa-3x"></i></div>
                    <a href="#" class="h4 mb-3">Nuestros Valores</a>
                    <p class="mb-3">Discipulado natural, refugio y seguridad, amor y compañerismo, crecimiento integral, testimonio activo y capacitación continua.</p>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Final Bienvenidos-->

<!-- Stacks -->
<div class="container-fluid counter py-5">
    <div class="container py-5">
        <div class="row g-5">
            <div class="col-md-6 col-lg-6 col-xl-3 wow fadeInUp" data-wow-delay="0.2s">
                <div class="counter-item">
                    <div class="counter-item-icon mx-auto">
                        <i class="fas fa-hands-helping fa-3x text-white"></i>
                    </div>
                    <h4 class="text-white my-4">Miembros</h4>
                    <div class="counter-counting">
                        <span class="text-white fs-2 fw-bold" data-toggle="counter-up">50</span>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-6 col-xl-3 wow fadeInUp" data-wow-delay="0.4s">
                <div class="counter-item">
                    <div class="counter-item-icon mx-auto">
                        <i class="fas fa-praying-hands fa-3x text-white"></i>
                    </div>
                    <h4 class="text-white my-4">Pastores</h4>
                    <div class="counter-counting">
                        <span class="text-white fs-2 fw-bold" data-toggle="counter-up">02</span>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-6 col-xl-3 wow fadeInUp" data-wow-delay="0.6s">
                <div class="counter-item">
                    <div class="counter-item-icon mx-auto">
                        <i class="fas fa-users fa-3x text-white"></i>
                    </div>
                    <h4 class="text-white my-4">Empleados</h4>
                    <div class="counter-counting">
                        <span class="text-white fs-2 fw-bold" data-toggle="counter-up">10</span>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-6 col-xl-3 wow fadeInUp" data-wow-delay="0.8s">
                <div class="counter-item">
                    <div class="counter-item-icon mx-auto">
                        <i class="fas fa-calendar-alt fa-3x text-white"></i>
                    </div>
                    <h4 class="text-white my-4">Años Juntos</h4>
                    <div class="counter-counting">
                        <span class="text-white fs-2 fw-bold" data-toggle="counter-up">2013</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Final Stacks -->

<!-- Nuestros Ministerios -->
<div class="container-fluid blog py-5">
    <div class="container py-5">
        <div class="text-center mx-auto pb-5 wow fadeInUp" data-wow-delay="0.2s" style="max-width: 800px;">
            <h4 class="text-uppercase text-primary">Nuestros Ministerios </h4>
            <h1 class="display-3 text-capitalize mb-3">Espacions diseñados para que crezcas en tu fé</h1>
        </div>
        <div class="row g-4 justify-content-center">
            <div class="col-lg-6 col-xl-4 wow fadeInUp" data-wow-delay="0.2s">
                <div class="blog-item">
                    <div class="blog-img">
                        <img src="~/img/blog-1.jpg" class="img-fluid rounded-top w-100" alt="">
                        <div class="blog-date px-4 py-2"><i class="fa fa-calendar-alt me-1"></i> Julio 27 2026</div>
                    </div>
                    <div class="blog-content rounded-bottom p-4">
                        <p class="h4 d-inline-block mb-3">Alabanza</p>
                        <p>Adoración en Espiruto</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 col-xl-4 wow fadeInUp" data-wow-delay="0.4s">
                <div class="blog-item">
                    <div class="blog-img">
                        <img src="~/img/blog-2.jpg" class="img-fluid rounded-top w-100" alt="">
                        <div class="blog-date px-4 py-2"><i class="fa fa-calendar-alt me-1"></i> Oct 12 2026</div>
                    </div>
                    <div class="blog-content rounded-bottom p-4">
                        <p class="h4 d-inline-block mb-3">Niños</p>
                        <p>Sembrando el futuro</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 col-xl-4 wow fadeInUp" data-wow-delay="0.6s">
                <div class="blog-item">
                    <div class="blog-img">
                        <img src="~/img/blog-3.jpg" class="img-fluid rounded-top w-100" alt="">
                        <div class="blog-date px-4 py-2"><i class="fa fa-calendar-alt me-1"></i> Dic 03 2026</div>
                    </div>
                    <div class="blog-content rounded-bottom p-4">
                        <a href="#" class="h4 d-inline-block mb-3">Jovenes</a>
                        <p>Pasión y proposito</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="py-5 carousel-caption-2-content-btn fadeInRight animated" data-animation="fadeInRight" data-delay="1.7s" style="animation-delay: 1.7s;">
            <a class="btn btn-secondary rounded-pill flex-shrink-0 py-3 px-5 ms-2" href="#">Ver más</a>
        </div>
    </div>
</div>
<!-- Final Ministerios  -->

<!-- Horarios  -->
<div class="container-fluid service bg-light overflow-hidden py-5">
    <div class="container py-5">
        <div class="text-center mx-auto pb-5 wow fadeInUp" data-wow-delay="0.2s" style="max-width: 800px;">
            <h4 class="text-uppercase text-primary">Te Esperamos</h4>
            <h1 class="display-3 text-capitalize mb-3">Ven y sé parte de nuestra familia</h1>
        </div>
        <div class="row g-4 align-items-center justify-content-center">
            <div class="col-lg-6 col-xl-4 wow fadeInLeft" data-wow-delay="0.2s">
                <div class="service-item rounded p-4 mb-4">
                    <div class="row">
                        <div class="col-12">
                            <div class="d-flex">
                                <div class="pe-4">
                                    <div class="service-btn">
                                        <i class="fas fa-calendar-check text-white fa-2x"></i>
                                    </div>
                                </div>
                                <div class="service-content">
                                    <p class="h4 d-inline-block mb-3">Sabados</p>
                                    <p class="mb-0">10:00 AM - Servicio Principal</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6 col-xl-4 wow fadeInRight" data-wow-delay="0.2s">
                <div class="service-item rounded p-4 mb-4">
                    <div class="row">
                        <div class="col-12">
                            <div class="d-flex">
                                <div class="pe-4">
                                    <div class="service-btn">
                                        <i class="fas fa-calendar-check text-white fa-2x"></i>
                                    </div>
                                </div>
                                <div class="service-content">
                                    <p class="h4 d-inline-block mb-3">Domingos</p>
                                    <p class="mb-0">10:00 AM - Servicio Principal</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 text-center mt-3">
                <a class="btn btn-secondary rounded-pill py-3 px-5" href="#">Ver más</a>
            </div>
        </div>
    </div>
</div>
<!-- Final Horarios -->
