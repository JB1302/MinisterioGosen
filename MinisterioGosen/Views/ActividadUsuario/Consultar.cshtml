@model List<MinisterioGosen.Models.ActividadUsuarioModel>

@{
    ViewData["Title"] = "Participaciones en actividades";

    var participaciones = Model ?? new List<MinisterioGosen.Models.ActividadUsuarioModel>();
}

<div class="container py-4">

    <div class="card-body py-4">
        <div class="d-flex flex-column flex-md-row align-items-center justify-content-center gap-3 text-center text-md-start">
            <div>
                <i class="bi bi-people-fill text-primary display-5"></i>
            </div>

            <div>
                <h2 class="fw-bold mb-1">
                    Participaciones registradas
                </h2>

                <p class="text-muted mb-0">
                    Consulte los usuarios inscritos en las actividades del Ministerio Gosén.
                </p>
            </div>
        </div>
    </div>

    @if (participaciones.Any())
    {
        <div class="row g-4">
            @foreach (var item in participaciones)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100">

                        <div class="card-header bg-light border-0 py-3">
                            <div class="d-flex justify-content-between align-items-center gap-2">
                                <span class="badge rounded-pill text-primary border border-primary px-3 py-2">
                                    <i class="bi bi-calendar-event me-1"></i>
                                    Actividad #@item.Id_Actividad
                                </span>

                                <span class="badge rounded-pill bg-white text-success border border-success px-3 py-2">
                                    Usuario #@item.Id_Usuario
                                </span>
                            </div>
                        </div>

                        <div class="card-body p-4">

                            <div class="d-flex align-items-start gap-3 mb-4">
                                <div class="bg-primary bg-opacity-10 text-primary rounded-circle p-3">
                                    <i class="bi bi-person-check-fill fs-4"></i>
                                </div>

                                <div>
                                    <h5 class="fw-bold mb-1">
                                        @item.NombreUsuario
                                    </h5>

                                    <p class="text-muted small mb-0">
                                        Identificación: @item.IdentificacionUsuario
                                    </p>
                                </div>
                            </div>

                            <div class="list-group list-group-flush">

                                <div class="list-group-item px-0 d-flex align-items-center gap-3">
                                    <i class="bi bi-calendar-date text-primary fs-5"></i>
                                    <div>
                                        <div class="small text-muted">Fecha</div>
                                        <div class="fw-semibold">@item.Fecha.ToString("dd/MM/yyyy")</div>
                                    </div>
                                </div>

                                @if (item.Hora.HasValue)
                                {
                                    <div class="list-group-item px-0 d-flex align-items-center gap-3">
                                        <i class="bi bi-clock-fill text-primary fs-5"></i>
                                        <div>
                                            <div class="small text-muted">Hora</div>
                                            <div class="fw-semibold">@item.Hora.Value.ToString(@"hh\:mm")</div>
                                        </div>
                                    </div>
                                }

                            </div>

                        </div>

                        <div class="card-footer bg-light border-0 text-end py-3">
                            <span class="text-muted small">
                                <i class="bi bi-info-circle me-1"></i>
                                Información de participación
                            </span>
                        </div>

                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body text-center py-5">
                <i class="bi bi-person-x text-muted display-3"></i>

                <h4 class="fw-bold text-muted mt-3 mb-2">
                    No hay participaciones registradas
                </h4>

                <p class="text-muted mb-0">
                    Cuando se registren usuarios en actividades, aparecerán en esta sección.
                </p>
            </div>
        </div>
    }

</div>
