@model List<MinisterioGosen.Models.ActividadUsuarioModel>

@{
    ViewData["Title"] = "Participaciones";

    var participaciones = Model ?? new List<MinisterioGosen.Models.ActividadUsuarioModel>();
    var totalParticipaciones = participaciones.Count;
    var totalConHora = participaciones.Count(x => x.Hora != null);
}

<div class="container py-4">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h2 class="fw-bold mb-1">
                <i class="bi bi-people-fill me-2 text-primary"></i>
                Participaciones
            </h2>
            <p class="text-muted mb-0">
                Administración de usuarios inscritos en actividades.
            </p>
        </div>

        <a asp-controller="ActividadUsuario"
           asp-action="Crear"
           class="btn btn-primary rounded-pill px-4">
            <i class="bi bi-plus-circle-fill me-1"></i>
            Nueva participación
        </a>
    </div>

    <div class="row g-3 mb-4">

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                        <i class="bi bi-people-fill text-primary fs-4"></i>
                    </div>

                    <div>
                        <p class="text-muted mb-0 small">Total participaciones</p>
                        <h4 class="fw-bold mb-0">@totalParticipaciones</h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-success bg-opacity-10 p-3">
                        <i class="bi bi-clock-fill text-success fs-4"></i>
                    </div>

                    <div>
                        <p class="text-muted mb-0 small">Con hora registrada</p>
                        <h4 class="fw-bold mb-0">@totalConHora</h4>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white border-0 px-4 pt-4 pb-2">
            <h5 class="fw-bold mb-0">
                <i class="bi bi-list-ul me-2 text-primary"></i>
                Listado de participaciones
            </h5>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Código</th>
                            <th>Actividad</th>
                            <th>Usuario</th>
                            <th>Fecha</th>
                            <th>Hora</th>
                            <th class="text-end pe-4">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (participaciones.Any())
                        {
                            foreach (var item in participaciones)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <span class="badge rounded-pill bg-secondary px-3 py-2">
                                            #@item.Id_Actividad_Usuario
                                        </span>
                                    </td>

                                    <td>
                                        <div class="fw-semibold">
                                            @item.NombreActividad
                                        </div>
                                    </td>

                                    <td>
                                        <div class="fw-semibold">
                                            <i class="bi bi-person-fill me-1 text-success"></i>
                                            @item.IdentificacionUsuario - @item.NombreUsuario
                                        </div>
                                    </td>

                                    <td>
                                        <div class="small">
                                            <i class="bi bi-calendar-date me-1 text-primary"></i>
                                            @item.Fecha.ToString("dd/MM/yyyy")
                                        </div>
                                    </td>

                                    <td>
                                        @if (item.Hora != null)
                                        {
                                            <span>
                                                <i class="bi bi-clock me-1"></i>
                                                @item.Hora.Value.ToString(@"hh\:mm")
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Sin hora</span>
                                        }
                                    </td>

                                    <td class="text-end pe-4">
                                        <div class="btn-group" role="group">
                                            <a asp-controller="ActividadUsuario"
                                               asp-action="Editar"
                                               asp-route-id="@item.Id_Actividad_Usuario"
                                               class="btn btn-sm btn-outline-primary"
                                               title="Editar">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>

                                            <a asp-controller="ActividadUsuario"
                                               asp-action="Eliminar"
                                               asp-route-id="@item.Id_Actividad_Usuario"
                                               class="btn btn-sm btn-outline-danger"
                                               title="Eliminar">
                                                <i class="bi bi-trash-fill"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5">
                                    <i class="bi bi-person-x text-muted display-4"></i>

                                    <h5 class="fw-bold text-muted mt-3 mb-1">
                                        No hay participaciones registradas
                                    </h5>

                                    <p class="text-muted mb-3">
                                        Cuando se registren usuarios en actividades, aparecerán en este listado.
                                    </p>

                                    <a asp-controller="ActividadUsuario"
                                       asp-action="Crear"
                                       class="btn btn-primary rounded-pill px-4">
                                        <i class="bi bi-plus-circle-fill me-1"></i>
                                        Crear participación
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
