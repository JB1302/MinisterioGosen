@model MinisterioGosen.Models.MinisterioModel

@{
    ViewData["Title"] = "Eliminar ministerio";
}

<div class="container py-4">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h2 class="fw-bold mb-1">
                <i class="bi bi-trash-fill me-2 text-danger"></i>
                Eliminar ministerio
            </h2>
            <p class="text-muted mb-0">
                Confirme si desea eliminar físicamente este ministerio.
            </p>
        </div>

        <a asp-controller="Ministerio"
           asp-action="Index"
           class="btn btn-outline-secondary rounded-pill px-4">
            <i class="bi bi-arrow-left me-1"></i>
            Volver
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">

            @if (ViewBag.Mensaje != null)
            {
                <div class="alert alert-warning d-flex align-items-center gap-2 rounded-3">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span>@ViewBag.Mensaje</span>
                </div>
            }

            <div class="alert alert-danger border-0 rounded-4 d-flex gap-3 align-items-start">
                <i class="bi bi-exclamation-triangle-fill fs-3"></i>

                <div>
                    <h5 class="fw-bold mb-1">Confirmación requerida</h5>
                    <p class="mb-0">
                        Esta acción eliminará el ministerio de forma permanente. Si tiene información relacionada, el sistema no permitirá eliminarlo.
                    </p>
                </div>
            </div>

            <div class="row g-3 my-4">
                <div class="col-md-4">
                    <div class="p-3 bg-light rounded-4">
                        <p class="text-muted small mb-1">Código</p>
                        <h6 class="fw-bold mb-0">#@Model.Id_Ministerio</h6>
                    </div>
                </div>

                <div class="col-md-8">
                    <div class="p-3 bg-light rounded-4">
                        <p class="text-muted small mb-1">Ministerio</p>
                        <h6 class="fw-bold mb-0">@Model.Descripcion_Ministerio</h6>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Observaciones_Ministerio))
                {
                    <div class="col-md-12">
                        <div class="p-3 bg-light rounded-4">
                            <p class="text-muted small mb-1">Observaciones</p>
                            <h6 class="fw-bold mb-0">@Model.Observaciones_Ministerio</h6>
                        </div>
                    </div>
                }
            </div>

            <form asp-controller="Ministerio"
                  asp-action="ConfirmarEliminar"
                  method="post">

                <input asp-for="Id_Ministerio" type="hidden" />
                <input asp-for="Descripcion_Ministerio" type="hidden" />
                <input asp-for="Observaciones_Ministerio" type="hidden" />

                <div class="d-flex justify-content-end gap-2">
                    <a asp-controller="Ministerio"
                       asp-action="Index"
                       class="btn btn-outline-secondary rounded-pill px-4">
                        Cancelar
                    </a>

                    <button type="submit"
                            class="btn btn-danger rounded-pill px-4">
                        <i class="bi bi-trash-fill me-1"></i>
                        Eliminar ministerio
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>