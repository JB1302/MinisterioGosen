@model List<MinisterioGosen.Models.MinisterioModel>

@{
    ViewData["Title"] = "Ministerios";

    var ministerios = Model ?? new List<MinisterioGosen.Models.MinisterioModel>();
    var totalMinisterios = ministerios.Count;
}

<div class="container py-4">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h2 class="fw-bold mb-1">
                <i class="bi bi-people-fill me-2 text-primary"></i>
                Ministerios
            </h2>
            <p class="text-muted mb-0">
                Administración de ministerios o grupos de apoyo registrados en el sistema.
            </p>
        </div>

        <a asp-controller="Ministerio"
           asp-action="Crear"
           class="btn btn-primary rounded-pill px-4">
            <i class="bi bi-plus-circle-fill me-1"></i>
            Nuevo ministerio
        </a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center"
                         style="width:48px;height:48px;">
                        <i class="bi bi-diagram-3-fill text-primary fs-4"></i>
                    </div>

                    <div>
                        <p class="text-muted mb-0 small">Total ministerios</p>
                        <h4 class="fw-bold mb-0">@totalMinisterios</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white border-0 px-4 pt-4 pb-2">
            <h5 class="fw-bold mb-0">
                <i class="bi bi-list-ul me-2 text-primary"></i>
                Listado de ministerios
            </h5>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Código</th>
                            <th>Ministerio</th>
                            <th>Observaciones</th>
                            <th class="text-end pe-4">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (ministerios.Any())
                        {
                            foreach (var item in ministerios)
                            {
                                <tr>
                                    <td class="ps-4 fw-semibold">
                                        <span class="badge rounded-pill bg-secondary px-3 py-2">
                                            #@item.Id_Ministerio
                                        </span>
                                    </td>

                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center"
                                                 style="width:34px;height:34px;min-width:34px;">
                                                <i class="bi bi-people-fill text-primary"></i>
                                            </div>

                                            <span class="fw-semibold">@item.Descripcion_Ministerio</span>
                                        </div>
                                    </td>

                                    <td>
                                        @if (!string.IsNullOrEmpty(item.Observaciones_Ministerio))
                                        {
                                            <span>@item.Observaciones_Ministerio</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Sin observaciones</span>
                                        }
                                    </td>

                                    <td class="text-end pe-4">
                                        <div class="btn-group" role="group">
                                            <a asp-controller="UsuariosMinisterio"
                                               asp-action="AsignarPersona"
                                               asp-route-idMinisterio="@item.Id_Ministerio"
                                               class="btn btn-info btn-sm">
                                                Asignar persona
                                            </a>
                                            
                                            <a asp-controller="Ministerio"
                                               asp-action="Editar"
                                               asp-route-id="@item.Id_Ministerio"
                                               class="btn btn-sm btn-outline-primary"
                                               title="Editar">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>

                                            <a asp-controller="Ministerio"
                                               asp-action="Eliminar"
                                               asp-route-id="@item.Id_Ministerio"
                                               class="btn btn-sm btn-outline-danger"
                                               title="Eliminar">
                                                <i class="bi bi-trash-fill"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5">
                                    <i class="bi bi-inbox text-muted display-4"></i>

                                    <h5 class="fw-bold text-muted mt-3 mb-1">
                                        No hay ministerios registrados
                                    </h5>

                                    <p class="text-muted mb-3">
                                        Cuando se creen ministerios, aparecerán en este listado.
                                    </p>

                                    <a asp-controller="Ministerio"
                                       asp-action="Crear"
                                       class="btn btn-primary rounded-pill px-4">
                                        <i class="bi bi-plus-circle-fill me-1"></i>
                                        Crear ministerio
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>