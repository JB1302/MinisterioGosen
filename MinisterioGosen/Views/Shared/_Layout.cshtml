@{
    var nombre = Context.Session.GetString("Nombre");
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <title>@ViewData["Title"] - Ministerio Gosén</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta content="" name="keywords">
    <meta content="" name="description">

    <!-- Icon Font Stylesheet -->
    <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.15.4/css/all.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Libraries Stylesheet -->
    <link href="~/css/animate.min.css" rel="stylesheet">
    <link href="~/css/owl.carousel.min.css" rel="stylesheet">

    <!-- Customized Bootstrap Stylesheet -->
    <link href="~/css/bootstrap.min.css" rel="stylesheet">

    <!-- Template Stylesheet -->
    <link href="~/css/style.css" rel="stylesheet" asp-append-version="true">

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js" asp-append-version="true"></script>
</head>

<body>
    <!-- Navbar & Hero Start -->


    <nav class="navbar navbar-expand-lg navbar-dark shadow-sm px-4 px-lg-5 py-2 sticky-top"
         style="background-color: #0d2422;">

        <a asp-action="Principal" asp-controller="Home" class="navbar-brand d-flex align-items-center">
            <img src="~/img/logo-gosen.png" alt="Logo Gosén" style="height: 65px;">
        </a>

        <button class="navbar-toggler border-0"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarCollapse"
                aria-controls="navbarCollapse"
                aria-expanded="false"
                aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarCollapse">
            <div class="navbar-nav ms-auto align-items-lg-center gap-lg-2">

                <a asp-action="Principal" asp-controller="Home" class="nav-link active fw-semibold">
                    <i class="bi bi-house-door me-1"></i> Inicio
                </a>

                <a asp-action="Principal" asp-controller="Home" class="nav-link fw-semibold">
                    <i class="bi bi-calendar-event me-1"></i> Actividades
                </a>

                <a asp-action="Principal" asp-controller="Home" class="nav-link fw-semibold">
                    <i class="bi bi-clock me-1"></i> Horarios
                </a>

                <a asp-action="Principal" asp-controller="Home" class="nav-link fw-semibold">
                    <i class="bi bi-people me-1"></i> Ministerios
                </a>

                @if (!string.IsNullOrEmpty(nombre))
                {
                    <a asp-action="Principal" asp-controller="Home" class="nav-link fw-semibold">
                        <i class="bi bi-calendar-plus me-1"></i> Agendar Cita
                    </a>

                    <a asp-action="Principal" asp-controller="Home" class="nav-link fw-semibold">
                        <i class="bi bi-bar-chart me-1"></i> Reportes
                    </a>
                }

                @if (!string.IsNullOrEmpty(nombre))
                {
                    <div class="dropdown ms-lg-3 mt-3 mt-lg-0">
                        <a href="#"
                           role="button"
                           class="dropdown-toggle d-flex align-items-center gap-2 text-decoration-none text-white"
                           data-bs-toggle="dropdown"
                           aria-expanded="false">

                            <div class="rounded-circle d-flex align-items-center justify-content-center"
                                 style="width:36px;height:36px;min-width:36px;background-color:#064442;">
                                <i class="bi bi-person-fill text-white"></i>
                            </div>

                            <span class="d-none d-md-block fw-semibold">@nombre</span>
                        </a>

                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                            <li>
                                <a class="dropdown-item py-2 d-flex align-items-center gap-2"
                                   asp-controller="Usuario"
                                   asp-action="Configuracion">
                                    <i class="bi bi-shield-lock text-warning fs-5"></i>
                                    <span>Configuración</span>
                                </a>
                            </li>

                            <li>
                                <hr class="dropdown-divider">
                            </li>

                            <li>
                                <a class="dropdown-item py-2 d-flex align-items-center gap-2 text-danger"
                                   asp-controller="Home"
                                   asp-action="Salir">
                                    <i class="bi bi-box-arrow-right fs-5"></i>
                                    <span>Salir</span>
                                </a>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <a asp-action="Index"
                       asp-controller="Home"
                       class="btn rounded-pill px-4 ms-lg-3 mt-3 mt-lg-0 text-white"
                       style="background-color: #064442;">
                        <i class="bi bi-box-arrow-in-right me-1"></i> Iniciar Sesión
                    </a>
                }

            </div>
        </div>
    </nav>


    @RenderBody()

    <!-- Footer Start -->
    <div class="container-fluid footer py-5 wow fadeIn" data-wow-delay="0.2s">
        <div class="container py-5">
            <div class="row g-5">

                <div class="col-md-6 col-lg-6 col-xl-3">
                    <div class="footer-item d-flex flex-column">
                        <div class="footer-item">
                            <a href="" class="navbar-brand p-0">
                                <img src="~/img/logo-gosen.png" alt="Logo Gosén" style="max-width: 120px; height: auto;">
                            </a>

                            <p class="mt-4">
                                Somos más que una iglesia, somos una familia unida por el amor de Cristo.
                                Comprometida con la transformación de nuestra comunidad.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 col-lg-6 col-xl-3">
                    <div class="footer-item d-flex flex-column">
                        <h4 class="text-white mb-4">Visítanos</h4>

                        <p class="mb-1">
                            <i class="fa fa-map-marker-alt me-2"></i>
                            Av. Principal de la Ciudad, Edificio Gosén, Nivel 1
                        </p>

                        <p class="mb-1">
                            <i class="fas fa-envelope me-2"></i>
                            ministeriogosen@gmail.com
                        </p>

                        <p class="mb-1">
                            <i class="fas fa-phone me-2"></i>
                            (+506) 0000 0000
                        </p>
                    </div>
                </div>

            </div>

            <div class="row g-5 mb-5 align-items-center mt-2">
                <div class="col-lg-12">
                    <div class="d-flex align-items-center justify-content-start">
                        <a class="btn btn-secondary btn-md-square rounded-circle me-3" href="">
                            <i class="fab fa-facebook-f"></i>
                        </a>

                        <a class="btn btn-secondary btn-md-square rounded-circle me-3" href="">
                            <i class="fab fa-whatsapp"></i>
                        </a>

                        <a class="btn btn-secondary btn-md-square rounded-circle me-3" href="">
                            <i class="fab fa-instagram"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Footer End -->

    <!-- Copyright Start -->
    <div class="container-fluid copyright py-4">
        <div class="container">
            <div class="row g-4 align-items-center">

                <div class="col-md-6 text-center text-md-start mb-md-0">
                    <span class="text-body">
                        <i class="fas fa-copyright text-light me-2"></i>
                        2026 Ministerio Gosén, Todos los derechos reservados.
                    </span>
                </div>

                <div class="col-md-6 text-center text-md-end text-body">
                    Creado por Grupo 01
                </div>

            </div>
        </div>
    </div>
    <!-- Copyright End -->

    <!-- Floating Buttons -->
    <a asp-action="Principal" asp-controller="Home"
       class="btn btn-secondary rounded-circle d-flex align-items-center justify-content-center shadow"
       style="position: fixed; right: 95px; bottom: 30px; width: 50px; height: 50px; z-index: 9999;"
       title="Chatbot">
        <i class="bi bi-chat-dots fs-4"></i>
    </a>

    <a href="#"
       class="btn btn-primary rounded-circle d-flex align-items-center justify-content-center shadow back-to-top"
       style="position: fixed; right: 30px; bottom: 30px; width: 50px; height: 50px; z-index: 9999;"
       title="Subir">
        <i class="bi bi-arrow-up fs-4"></i>
    </a>

    <script src="~/js/wow.min.js"></script>
    <script src="~/js/easing.min.js"></script>
    <script src="~/js/waypoints.min.js"></script>
    <script src="~/js/counterup.min.js"></script>
    <script src="~/js/owl.carousel.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Template Javascript -->
    <script src="~/js/main.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>